{
  "swagger": "2.0",
  "info": {
    "title": "pharmacies-seeker",
    "version": "1.0.0",
    "description": "API for querying pharmacies and duty pharmacies with in-memory caching."
  },
  "schemes": [
    "http"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/health/live": {
      "get": {
        "summary": "Liveness probe",
        "responses": {
          "200": {
            "description": "Service is live",
            "schema": {
              "$ref": "#/definitions/HealthResponse"
            }
          }
        }
      }
    },
    "/health/ready": {
      "get": {
        "summary": "Readiness probe",
        "responses": {
          "200": {
            "description": "Catalogs are synchronized",
            "schema": {
              "$ref": "#/definitions/HealthResponse"
            }
          },
          "503": {
            "description": "Catalogs are not synchronized yet",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    },
    "/api/v1/pharmacies": {
      "get": {
        "summary": "List pharmacies",
        "parameters": [
          {
            "name": "commune",
            "in": "query",
            "type": "string"
          },
          {
            "name": "name",
            "in": "query",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Pharmacy list",
            "schema": {
              "$ref": "#/definitions/PharmacyListResponse"
            }
          },
          "503": {
            "description": "Catalog unavailable",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    },
    "/api/v1/pharmacies/duty": {
      "get": {
        "summary": "List duty pharmacies",
        "parameters": [
          {
            "name": "commune",
            "in": "query",
            "type": "string"
          },
          {
            "name": "name",
            "in": "query",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Duty pharmacy list",
            "schema": {
              "$ref": "#/definitions/PharmacyListResponse"
            }
          },
          "503": {
            "description": "Catalog unavailable",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    },
    "/api/v1/pharmacies/{id}": {
      "get": {
        "summary": "Get pharmacy by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Pharmacy detail",
            "schema": {
              "$ref": "#/definitions/PharmacyResponse"
            }
          },
          "400": {
            "description": "Invalid ID",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "404": {
            "description": "Pharmacy not found",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "503": {
            "description": "Catalog unavailable",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "HealthResponse": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        }
      }
    },
    "Pharmacy": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "commune": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        }
      }
    },
    "PharmacyListResponse": {
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Pharmacy"
          }
        }
      }
    },
    "PharmacyResponse": {
      "type": "object",
      "properties": {
        "data": {
          "$ref": "#/definitions/Pharmacy"
        }
      }
    },
    "APIError": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "properties": {
        "error": {
          "$ref": "#/definitions/APIError"
        }
      }
    }
  }
}
